# model-monitor environment variables
# Copy this file to .env and fill in values before running the full stack.
# docker-compose reads .env automatically; for local runs, export or source it.
#
# Usage:
#   cp .env.example .env
#   # edit .env with real values
#   docker compose --profile monitoring up --build

# ── Ingest API ───────────────────────────────────────────────────────────────
# Required to POST to /metrics/ingest. When unset, the ingest endpoint
# returns HTTP 503 (administratively disabled, not an auth failure).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MONITOR_API_KEY=

# ── Dashboard API ────────────────────────────────────────────────────────────
# Optional. When set, all /dashboard/* routes require X-Api-Key: <value>.
# When unset, the dashboard is unauthenticated - fine for local dev or
# deployments protected at the network layer (VPN, reverse proxy, etc.).
MONITOR_DASHBOARD_KEY=

# ── Grafana ───────────────────────────────────────────────────────────────────
# Grafana admin password. Defaults to "admin" when unset - change for any
# non-local deployment.
GF_ADMIN_PASSWORD=admin
