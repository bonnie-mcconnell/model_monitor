data/metrics/*.db-wal
models/*.pkl
models/archive
models/active.json
models/candidate.pkl
models/current.pkl

# Notebooks and docs (not needed in image)
notebooks
*.md
*.rst
docs

# Tests (not needed in production image)
tests

# Scripts and dev tooling
scripts
Makefile
docker-compose.yml
