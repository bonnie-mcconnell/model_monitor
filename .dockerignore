# Git
.git
.gitignore

# Python cache
__pycache__
*.pyc
*.pyo
*.egg-info
.venv
venv

# Dev tools
.mypy_cache
.ruff_cache
.pytest_cache
.coverage
htmlcov

# Runtime artifacts (bind-mounted at runtime via docker-compose volumes)
