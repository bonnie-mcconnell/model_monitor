# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.hypothesis/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Type checking & linting ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Runtime data - never committed ───────────────────────────────────────────
# SQLite databases are created at runtime; committing them would mean every
# developer's local run history ends up in version control.
data/metrics/*.db
data/metrics/*.db-wal
data/metrics/*.db-shm

# Trained model artefacts - can be hundreds of MB.  The training script
# produces these; they are not source artefacts.
models/*.pkl
models/*.joblib
models/archive/
models/active.json

# Reference statistics written at training time - regenerated by make train.
# Committing these would let stale reference stats shadow a fresh training run.
data/reference/reference_stats.json

# Model cards - written alongside promoted models; regenerated automatically.
data/models/*.json

# ── Directories that must exist but have no tracked content ───────────────────
# data/metrics/, data/models/, data/reference/ are created at runtime.
# .gitkeep files in these directories ensure they exist on a clean clone.
!data/metrics/.gitkeep
!data/models/.gitkeep
!data/reference/.gitkeep

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
# Keep notebook outputs out of version control to avoid large diffs.
# Run notebooks locally; outputs are not reproducible across machines.

# ── Editors ───────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── Docker volumes ────────────────────────────────────────────────────────────
# Prometheus and Grafana write data into named volumes; local bind-mounts
# can appear here when overriding the compose file.
prometheus_data/
grafana_data/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
/tmp/
