{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping GET /metrics on the model_monitor server",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ],
  "title": "model-monitor \u2014 production monitoring",
  "uid": "model-monitor-v1",
  "description": "model-monitor: 7-component trust score, 3-layer drift stack (input PSI \u00b7 output PSI \u00b7 conformal coverage), data quality, tail latency.",
  "tags": [
    "model-monitor",
    "ml-ops",
    "drift",
    "monitoring"
  ],
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "pluginId": "prometheus",
        "refresh": 1,
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "current": {}
      },
      {
        "name": "window",
        "label": "Aggregation window",
        "type": "custom",
        "options": [
          {
            "value": "5m",
            "text": "5 minutes",
            "selected": true
          },
          {
            "value": "1h",
            "text": "1 hour",
            "selected": false
          },
          {
            "value": "24h",
            "text": "24 hours",
            "selected": false
          }
        ],
        "current": {
          "value": "5m",
          "text": "5 minutes"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 99,
      "title": "",
      "type": "text",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## model-monitor\n**Trust score** = weighted sum of accuracy (30%), F1 (25%), confidence (15%), drift (20%), latency (10%). Values below 0.7 trigger retraining; below 0.5 trigger rollback. PSI > 0.2 = significant drift. All panels update every 30 seconds."
      }
    },
    {
      "id": 1,
      "title": "Trust score",
      "description": "Weighted combination of accuracy, F1, confidence, drift, and latency. Below 0.70 fires a warning alert; below 0.60 fires critical.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "model_monitor_trust_score{window=\"$window\"}",
          "legendFormat": "trust score ({{window}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "PSI drift score",
      "description": "Population Stability Index averaged across all features. Below 0.10 = stable; 0.10\u20130.20 = moderate; above 0.20 = reject threshold.",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          },
          "min": 0,
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "model_monitor_drift_score{window=\"$window\"}",
          "legendFormat": "PSI ({{window}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 102,
      "title": "Data Quality Score",
      "description": "Aggregate score [0\u20131] from null rate, out-of-range values, and schema consistency checks. Below 0.80 means incoming data cannot be trusted \u2014 PSI and F1 metrics may be misleading.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#2ecc71"
          },
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "model_monitor_data_quality_score{window=\"5m\"}",
          "legendFormat": "{{window}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "title": "Conformal Coverage Rate",
      "description": "Fraction of labeled samples whose true label fell within the conformal prediction set. Should stay \u2265 0.90 (the 1\u2212alpha guarantee). A sustained drop below 0.85 is a provable signal of model quality degradation.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#9b59b6"
          },
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.85
              },
              {
                "color": "green",
                "value": 0.9
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "model_monitor_conformal_coverage{window=\"5m\"}",
          "legendFormat": "{{window}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "title": "Output Distribution PSI",
      "description": "PSI on predicted probability vectors. Detects prediction distribution shift before batch F1 degrades. Threshold: warn >0.10, critical >0.25.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#e67e22"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.25
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "model_monitor_output_drift_score{window=\"5m\"}",
          "legendFormat": "{{window}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 104,
      "title": "Conformal Prediction Set Size",
      "description": "Mean number of classes in each conformal prediction set. A well-calibrated confident model should have set size \u2248 1.0. Growing set size signals increasing model uncertainty \u2014 actionable even without ground-truth labels.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#1abc9c"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1.5
              },
              {
                "color": "red",
                "value": 2.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "model_monitor_conformal_set_size{window=\"5m\"}",
          "legendFormat": "{{window}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "F1 score vs baseline",
      "description": "Current F1 against the baseline written at promotion time. A sustained gap triggers retrain; a large gap triggers rollback.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "model_monitor_f1{window=\"$window\"}",
          "legendFormat": "F1 ({{window}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "model_monitor_f1_baseline",
          "legendFormat": "baseline F1",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Accuracy",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "model_monitor_accuracy{window=\"$window\"}",
          "legendFormat": "accuracy ({{window}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Decision actions (cumulative)",
      "description": "Monotonically increasing counters per action type. A rising retrain rate indicates ongoing instability.",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "model_monitor_decisions_total",
          "legendFormat": "{{action}}",
          "refId": "A",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7
      }
    },
    {
      "id": 6,
      "title": "Current trust score",
      "type": "gauge",
      "gridPos": {
        "x": 8,
        "y": 27,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "model_monitor_trust_score{window=\"5m\"}",
          "legendFormat": "trust (5m)",
          "refId": "A",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Expected Calibration Error",
      "description": "ECE measures whether confidence scores match actual accuracy. High F1 with high ECE indicates an overconfident model.",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 27,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "model_monitor_calibration_error{window=\"$window\"}",
          "legendFormat": "ECE ({{window}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Model version",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "model_monitor_model_version_info",
          "legendFormat": "{{version}}",
          "refId": "A",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "name"
      }
    },
    {
      "id": 9,
      "title": "Batch count",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 35,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "model_monitor_n_batches{window=\"$window\"}",
          "legendFormat": "batches ({{window}})",
          "refId": "A",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 10,
      "title": "Decision latency",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 40
      },
      "collapsed": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 11,
      "title": "Decision latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 41
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6,
            "spanNulls": true
          },
          "unit": "ms",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.50, sum(rate(model_monitor_decision_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.95, sum(rate(model_monitor_decision_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.99, sum(rate(model_monitor_decision_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 12,
      "title": "Decision latency heatmap",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 41
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "ms"
        },
        "color": {
          "scheme": "Oranges",
          "mode": "scheme"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(model_monitor_decision_latency_ms_bucket[2m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 13,
      "title": "Behavioral contracts",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 50
      },
      "collapsed": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "id": 14,
      "title": "Behavioral violation rate (EMA)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 51
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#FF7383"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": true
          },
          "unit": "percentunit",
          "min": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "model_monitor_trust_score{window=\"1h\"}",
          "legendFormat": "{{window}}"
        }
      ]
    },
    {
      "id": 15,
      "title": "Decision actions",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 60
      },
      "collapsed": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
